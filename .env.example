APP_NAME="University Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/college_management_system/public

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=university_management_system
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@university.com"
MAIL_FROM_NAME="${APP_NAME}"

SMS_DRIVER=africastalking
SMS_USERNAME=
SMS_API_KEY=

UNIVERSITY_NAME="Your University Name"
UNIVERSITY_SHORT_NAME=UN
UNIVERSITY_ADDRESS="Your Address"
UNIVERSITY_PHONE="+000 000 000000"
UNIVERSITY_EMAIL="info@university.com"
UNIVERSITY_WEBSITE="https://university.com"

# -------------------------------------------------------
# PRODUCTION VALUES — change all of these before go-live
# -------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://yourdomain.com
# LOG_LEVEL=error
# SESSION_SECURE_COOKIE=true
# SESSION_DRIVER=database
# QUEUE_CONNECTION=database
